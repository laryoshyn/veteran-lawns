# SMTP Email (for sending payment links — optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@veteranlawnsandlandscapes.com

# Mobile Text Alerts (optional — SMS notifications)
MTA_API_KEY=
MTA_ACCOUNT_ID=

# Zillow API via RapidAPI (optional — property data & valuation)
ZILLOW_API_KEY=
ZILLOW_API_HOST=zillow-com.p.rapidapi.com

# E-Verify (optional — employment eligibility verification)
EVERIFY_CLIENT_ID=
